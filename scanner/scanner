<!-- 
scanner/dashboard.html
담당: 김성환 | 로그 조회 및 검색/필터 레이아웃
-->

<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🛡️ 보안 로그 대시보드</title>
    <!-- 부트스트랩으로 깔끔한 디자인 적용 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <div class="container mt-5">
        <h2 class="mb-4">📂 파일 보안 스캔 및 자동 정리 기록</h2>

        <!-- ──────────────────────────────────────────────
             검색 및 필터링 폼 세션 (추가된 기능)
             ────────────────────────────────────────────── -->
        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <form method="GET" action="" class="row g-3 align-items-center">
                    <!-- 파일명 검색창 -->
                    <div class="col-md-5">
                        <label class="form-label d-none">파일명 검색</label>
                        <input type="text" name="search" class="form-style form-control" 
                               placeholder="🔍 파일명 검색..." value="{{ search_query }}">
                    </div>
                    
                    <!-- 상태 필터 드롭다운 -->
                    <div class="col-md-4">
                        <select name="status" class="form-select">
                            <option value="">🌐 전체 상태 보기</option>
                            <option value="clean" {% if status_filter == 'clean' %}selected{% endif %}>✅ 안전</option>
                            <option value="suspicious" {% if status_filter == 'suspicious' %}selected{% endif %}>⚠️ 의심</option>
                            <option value="malicious" {% if status_filter == 'malicious' %}selected{% endif %}>🚨 악성</option>
                            <option value="error" {% if status_filter == 'error' %}selected{% endif %}>❌ 오류</option>
                        </select>
                    </div>

                    <!-- 검색 버튼 및 초기화 -->
                    <div class="col-md-3 d-flex gap-2">
                        <button type="submit" class="btn btn-primary w-100">적용하기</button>
                        <a href="?" class="btn btn-outline-secondary w-100">초기화</a>
                    </div>
                </form>
            </div>
        </div>

        <!-- ──────────────────────────────────────────────
             로그 출력 테이블 세션
             ────────────────────────────────────────────── -->
        <div class="card shadow">
            <div class="card-body">
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>스캔 일시</th>
                            <th>파일명</th>
                            <th>보안 상태</th>
                            <th>탐지율</th>
                            <th>압축</th>
                            <th>최종 저장 경로</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for log in logs %}
                        <tr>
                            <td>{{ log.created_at|date:"Y-m-d H:i:s" }}</td>
                            <td><strong>{{ log.file_name }}</strong></td>
                            <td>
                                <span class="badge 
                                    {% if log.status == 'clean' %}bg-success
                                    {% elif log.status == 'malicious' %}bg-danger
                                    {% else %}bg-warning text-dark{% endif %}">
                                    {{ log.get_status_display }}
                                </span>
                            </td>
                            <td>{{ log.detections }} / {{ log.total_engines }}</td>
                            <td>{{ log.is_compressed|yesno:"✅,❌" }}</td>
                            <td><small class="text-muted">{{ log.saved_path }}</small></td>
                        </tr>
                        {% empty %}
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">조건에 맞는 스캔 데이터가 없습니다.</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        <p class="text-end mt-3 text-muted">담당자: 김성환</p>
    </div>

</body>
</html>
